{
  "tasks": {
    "test": "deno test -A",
    "test:watch": "deno test -A --watch"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@testing-library/react": "npm:@testing-library/react@^16.3.2",
    "@types/react": "npm:@types/react@^19.2.14",
    "jsdom": "npm:jsdom@^29.0.2",
    "react": "npm:react@^19.2.5",
    "react-dom": "npm:react-dom@^19.2.5"
  },
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "jsxImportSourceTypes": "@types/react"
  }
}
