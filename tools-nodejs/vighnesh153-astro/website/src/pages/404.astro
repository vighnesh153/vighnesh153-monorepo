---
import BaseLayout from "../layouts/BaseLayout.astro";
import { internalLinks } from "@/utils/content/links";
---

<BaseLayout
  title="Page not found"
  description={"Lost? Head over to " + internalLinks.host}
>
  <main class="loading">
    <h1>404: Not found</h1>
  </main>
</BaseLayout>

<style lang="css">
  main {
    margin: auto;
    padding: 1.5rem;
    max-width: 60ch;
  }
  main.loading {
    display: none;
  }

  h1 {
    font-size: 3rem;
    font-weight: 800;
    margin: 0;
  }
</style>

<script>
  import { removeTrailingSlashFromUrlPathName } from "@/utils/removeTrailingSlashFromUrlPathName.ts";
  import { logAnalyticsEvent } from "@/utils/analytics.ts";

  const rawUrl = window.location.toString();
  const filteredUrl = removeTrailingSlashFromUrlPathName(rawUrl);

  logAnalyticsEvent("visit_404", { url: rawUrl });

  if (filteredUrl !== rawUrl) {
    window.location.replace(filteredUrl);
  } else {
    document.querySelector("main")?.classList.remove("loading");
  }
</script>
