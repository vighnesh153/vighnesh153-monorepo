{
  "extends": "@vighnesh153/tsconfig/astro.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES6",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "types": [
      "vite/client",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.astro",
    "./.astro/types.d.ts"
  ],
  "exclude": [
    "dist",
    "build",
    "node_modules"
  ]
}